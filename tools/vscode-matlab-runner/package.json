{
  "name": "matlab-file-runner",
  "displayName": "MATLAB File Runner",
  "description": "Run selected MATLAB .m files from VS Code with configurable desktop or batch launch.",
  "version": "0.2.0",
  "publisher": "internal-tools",
  "author": {
    "name": "Victor Kräh"
  },
  "icon": "media/icon.png",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:matlabFileRunner.runSelectedFiles",
    "onCommand:matlabFileRunner.runCurrentFile"
  ],
  "main": "./out/src/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test \"out/test/**/*.test.js\"",
    "package": "npm run compile && vsce package --allow-missing-repository --out matlab-file-runner-0.2.0.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "^5.7.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "matlabFileRunner.runSelectedFiles",
        "title": "MATLAB: Run Selected File(s)",
        "category": "MATLAB"
      },
      {
        "command": "matlabFileRunner.runCurrentFile",
        "title": "MATLAB: Run Current File",
        "category": "MATLAB"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "matlabFileRunner.runSelectedFiles",
          "when": "resourceExtname == .m",
          "group": "navigation@90"
        }
      ],
      "editor/context": [
        {
          "command": "matlabFileRunner.runCurrentFile",
          "when": "resourceExtname == .m",
          "group": "navigation@90"
        }
      ],
      "editor/title/context": [
        {
          "command": "matlabFileRunner.runCurrentFile",
          "when": "resourceExtname == .m",
          "group": "navigation@90"
        }
      ]
    },
    "configuration": {
      "title": "MATLAB File Runner",
      "properties": {
        "matlabFileRunner.executable": {
          "type": "string",
          "default": "matlab",
          "description": "MATLAB executable or full path to matlab.exe."
        },
        "matlabFileRunner.launchMode": {
          "type": "string",
          "enum": [
            "desktop",
            "batch"
          ],
          "default": "desktop",
          "description": "Choose whether MATLAB starts with its desktop or runs the command in batch mode."
        },
        "matlabFileRunner.terminalMode": {
          "type": "string",
          "enum": [
            "visible",
            "detached"
          ],
          "default": "visible",
          "description": "Choose whether MATLAB is launched from a visible VS Code terminal or as a detached process."
        },
        "matlabFileRunner.stopOnError": {
          "type": "boolean",
          "default": true,
          "description": "Stop the selected file sequence when a MATLAB error occurs."
        },
        "matlabFileRunner.addFileDirectoryToPath": {
          "type": "boolean",
          "default": true,
          "description": "Add each selected file's directory to the MATLAB path before running it."
        }
      }
    }
  }
}
